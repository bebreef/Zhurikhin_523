<Page x:Class="Pr14.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        Content="← На главную" 
                        Padding="16,8" 
                        FontSize="14" 
                        Click="Back_Click"
                        HorizontalAlignment="Left"/>

                <TextBlock Grid.Column="1" 
                           Text="Личный кабинет" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2" 
                        Content="Выйти из аккаунта" 
                        Padding="16,8" 
                        Background="#E74C3C" 
                        Foreground="White" 
                        Click="Logout_Click"
                        HorizontalAlignment="Right"/>
            </Grid>

            <Border Grid.Row="1" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="25" 
                    Background="#F9FAFB"
                    Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="Информация об аккаунте" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Логин:" FontWeight="Medium" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentLogin}" FontSize="16" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ФИО:" FontWeight="Medium" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentFullName}" FontSize="16" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Email:" FontWeight="Medium" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentEmail}" FontSize="16" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Телефон:" FontWeight="Medium" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentPhone}" FontSize="16" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="25" 
                    Background="#F9FAFB">
                <StackPanel>
                    <TextBlock Text="Ваши билеты" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,15"/>

                    <ListView x:Name="lvTickets" 
                              ItemsSource="{Binding Tickets}" 
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Фильм" Width="250">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MovieTitle}" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Сеанс" Width="180">
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="SessionDateTime" StringFormat="dd.MM.yyyy HH:mm"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Header="Зал" Width="100" DisplayMemberBinding="{Binding HallName}"/>
                                <GridViewColumn Header="Место" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Place}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Цена" Width="100">
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="Price" StringFormat="{}{0:N0} ₽"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Header="Куплен" Width="140">
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="PurchaseDate" StringFormat="dd.MM.yyyy HH:mm"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock x:Name="tbNoTickets" 
                               Text="У вас пока нет билетов" 
                               FontStyle="Italic" 
                               Foreground="Gray" 
                               Margin="0,10,0,0" 
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>