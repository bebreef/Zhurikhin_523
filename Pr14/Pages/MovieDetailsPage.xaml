<Page x:Class="Pr14.Pages.MovieDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MovieDetailsPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
                <Button Content="← Назад" Padding="12,6" Click="Back_Click"/>
                <TextBlock x:Name="tbTitle" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Margin="20,0,0,0" 
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="25" 
                    Background="#F9FAFB"
                    Margin="0,0,0,30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="imgPoster" 
                           Grid.Column="0" 
                           Width="300" 
                           Height="450" 
                           Stretch="UniformToFill" 
                           Margin="0,0,20,0"/>

                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Рейтинг:" FontWeight="Medium" Margin="0,0,10,0"/>
                            <TextBlock x:Name="tbRating" FontSize="16"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Возрастной рейтинг:" FontWeight="Medium" Margin="0,0,10,0"/>
                            <TextBlock x:Name="tbAge" FontSize="16" Foreground="Red"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="В прокате с:" FontWeight="Medium" Margin="0,0,10,0"/>
                            <TextBlock x:Name="tbRelease" FontSize="16"/>
                        </StackPanel>

                        <TextBlock Text="Описание:" FontWeight="Medium" Margin="0,0,0,5"/>
                        <TextBlock x:Name="tbDescription" 
                                   FontSize="14" 
                                   TextWrapping="Wrap" 
                                   LineHeight="20"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="25" 
                    Background="#F9FAFB">
                <StackPanel>
                    <TextBlock Text="Сеансы" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <ItemsControl ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#DDD" 
                                        BorderThickness="1" 
                                        Margin="0,0,0,10" 
                                        Padding="15" 
                                        CornerRadius="8">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Width="300">
                                            <TextBlock Text="{Binding StartDateTime, StringFormat=dd.MM.yyyy HH:mm}" 
                                                       FontSize="16" 
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding HallName}" FontSize="14" Margin="0,5,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   VerticalAlignment="Center" 
                                                   Margin="0,0,20,0"/>
                                        <Button Content="Выбрать сеанс" 
                                                Padding="12,6" 
                                                Click="SelectSession_Click"
                                                Tag="{Binding Id}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="tbNoSessions" 
                               Text="Сеансы не найдены" 
                               FontStyle="Italic" 
                               Foreground="Gray" 
                               Margin="0,10,0,0" 
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>