<Page x:Class="Pr14.Pages.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SessionPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="← Назад" Padding="12,6" Click="Back_Click"/>
            <TextBlock x:Name="tbSessionInfo" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Margin="20,0,0,0" 
                       VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="seatsPanel" Orientation="Vertical" HorizontalAlignment="Center"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <TextBlock Text="Выбрано мест:" 
                       FontSize="16" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"/>
            <TextBlock x:Name="tbSelectedCount" 
                       Text="0" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="0,0,20,0"/>
            <Button x:Name="btnConfirm" 
                    Content="Оформить билет(ы)" 
                    Padding="16,8" 
                    IsEnabled="False"
                    Click="ConfirmTicket_Click"/>
        </StackPanel>
    </Grid>
</Page>