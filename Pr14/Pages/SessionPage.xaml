<Page x:Class="Pr14.Pages.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#0D0D0D"
      Title="SessionPage">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
            <Button Content="← Назад" 
                    Padding="16,10" 
                    FontSize="14"
                    Foreground="White"
                    Background="#B22222"
                    BorderBrush="#8B0000"
                    Click="Back_Click"/>

            <TextBlock x:Name="tbSessionInfo"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="25,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="seatsPanel" 
                        Orientation="Vertical" 
                        HorizontalAlignment="Center"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,30,0,0">
            <TextBlock Text="Выбрано мест:"
                       FontSize="16"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <TextBlock x:Name="tbSelectedCount"
                       Text="0"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#FF4444"
                       Margin="0,0,25,0"/>
            <Button x:Name="btnConfirm"
                    Content="Оформить билет(ы)"
                    Padding="16,10"
                    FontSize="16"
                    Foreground="White"
                    Background="#B22222"
                    BorderBrush="#8B0000"
                    IsEnabled="False"
                    Click="ConfirmTicket_Click"/>
        </StackPanel>
    </Grid>
</Page>