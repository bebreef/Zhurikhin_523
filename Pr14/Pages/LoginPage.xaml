<Page x:Class="Pr14.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#0D0D0D"
      Title="LoginPage">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,40">
            <Button Content="← Назад"
                    Padding="16,10"
                    FontSize="14"
                    Foreground="White"
                    Background="#B22222"
                    BorderBrush="#8B0000"
                    Click="Back_Click"/>

            <TextBlock Text="Вход в аккаунт"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="25,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" 
                MaxWidth="420" 
                VerticalAlignment="Center"
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="12"
                Padding="30"
                Background="#1A1A1A">
            <StackPanel>
                <TextBlock Text="Логин" 
                           Foreground="#CCCCCC" 
                           FontSize="14" 
                           Margin="0,0,0,6"/>

                <TextBox x:Name="tbLogin" 
                         Padding="12" 
                         FontSize="16"
                         Background="#222222"
                         Foreground="White"
                         BorderBrush="#444444"
                         Margin="0,0,0,18"/>

                <TextBlock Text="Пароль" 
                           Foreground="#CCCCCC" 
                           FontSize="14" 
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="tbPassword" 
                             Padding="12" 
                             FontSize="16"
                             Background="#222222"
                             Foreground="White"
                             BorderBrush="#444444"
                             Margin="0,0,0,25"/>

                <Button Content="Войти"
                        Padding="16,10"
                        FontSize="16"
                        Foreground="White"
                        Background="#B22222"
                        BorderBrush="#8B0000"
                        Click="btnLogin_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,40,0,0">
            <TextBlock Text="Нет аккаунта?" 
                       Foreground="#AAAAAA" 
                       VerticalAlignment="Center" 
                       Margin="0,0,12,0"/>
            <Button Content="Зарегистрироваться"
                    Padding="16,10"
                    FontSize="14"
                    Foreground="White"
                    Background="#B22222"
                    BorderBrush="#8B0000"
                    Click="btnRegister_Click"/>
        </StackPanel>
    </Grid>
</Page>