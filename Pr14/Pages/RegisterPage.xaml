<Page x:Class="Pr14.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0">
<Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
            <Button Content="← Назад" 
                    Padding="12,6" 
                    Click="Back_Click"/>
            <TextBlock Text="Регистрация" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="20,0,0,0" 
                       VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" MaxWidth="400" VerticalAlignment="Center">
            <TextBlock Text="Логин *" Margin="0,0,0,5"/>
            <TextBox x:Name="tbLogin" Padding="8" Margin="0,0,0,15"/>

            <TextBlock Text="Пароль *" Margin="0,0,0,5"/>
            <PasswordBox x:Name="tbPassword" Padding="8" Margin="0,0,0,15"/>

            <TextBlock Text="ФИО" Margin="0,0,0,5"/>
            <TextBox x:Name="tbFullName" Padding="8" Margin="0,0,0,15"/>

            <TextBlock Text="Email" Margin="0,0,0,5"/>
            <TextBox x:Name="tbEmail" Padding="8" Margin="0,0,0,15"/>

            <TextBlock Text="Телефон" Margin="0,0,0,5"/>
            <TextBox x:Name="tbPhone" Padding="8" Margin="0,0,0,20"/>

            <Button Content="Зарегистрироваться" 
                    Padding="12,8" 
                    Click="btnRegister_Click"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>
