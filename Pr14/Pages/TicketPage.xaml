<Page x:Class="Pr14.Pages.TicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TicketPage">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Подтверждение билета" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="0,0,0,30"/>

        <StackPanel Grid.Row="1">
            <TextBlock x:Name="tbFilm" FontSize="18" Margin="0,0,0,10"/>
            <TextBlock x:Name="tbSession" FontSize="16" Margin="0,0,0,10"/>
            <TextBlock x:Name="tbHall" FontSize="16" Margin="0,0,0,10"/>
            <TextBlock x:Name="tbPlaces" FontSize="16" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <TextBlock x:Name="tbTotalPrice" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="0,10,0,20"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="← Назад" Margin="0,0,20,0" Padding="16,8" Click="Back_Click"/>
            <Button Content="Подтвердить покупку" 
                    Padding="16,8" 
                    Background="#4CAF50" 
                    Foreground="White" 
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Page>
