<Page x:Class="Pr14.Pages.TicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#0D0D0D"
      Title="TicketPage">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Подтверждение билета"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,35"/>

        <Border Grid.Row="1"
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="12"
                Padding="30"
                Background="#1A1A1A">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Фильм:" 
                               FontSize="16" 
                               Foreground="#CCCCCC" 
                               Width="100"/>
                    <TextBlock x:Name="tbFilm" 
                               FontSize="16" 
                               Foreground="White"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Сеанс:" 
                               FontSize="16" 
                               Foreground="#CCCCCC" 
                               Width="100"/>
                    <TextBlock x:Name="tbSession" 
                               FontSize="16" 
                               Foreground="White"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Зал:" 
                               FontSize="16" 
                               Foreground="#CCCCCC" 
                               Width="100"/>
                    <TextBlock x:Name="tbHall" 
                               FontSize="16" 
                               Foreground="White"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Места:" 
                               FontSize="16" 
                               Foreground="#CCCCCC" 
                               Width="100"
                               VerticalAlignment="Top"/>
                    <TextBlock x:Name="tbPlaces" 
                               FontSize="16" 
                               Foreground="White" 
                               TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock x:Name="tbTotalPrice"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FF4444"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,35,0,0">
            <Button Content="← Назад" 
                    Margin="0,0,20,0" 
                    Padding="16,10" 
                    FontSize="14"
                    Foreground="White"
                    Background="#444444"
                    BorderBrush="#666666"
                    Click="Back_Click"/>

            <Button Content="Подтвердить покупку"
                    Padding="16,10"
                    FontSize="16"
                    Foreground="White"
                    Background="#B22222"
                    BorderBrush="#8B0000"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Page>